{
  "name": "@tiyogo/demo-overlay",
  "version": "0.1.0",
  "description": "Aesthetic, fully customizable \"This demo brought to you by Tiyogo\" overlay badge for React & Next.js demo previews.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vite": "^6.0.7"
  },
  "keywords": [
    "react",
    "nextjs",
    "overlay",
    "badge",
    "watermark",
    "demo",
    "preview",
    "tiyogo"
  ],
  "author": "Tiyogo (https://tiyogo.com)",
  "license": "MIT",
  "homepage": "https://tiyogo.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/returnednull/tiyogo-demo-overlay.git"
  },
  "bugs": {
    "url": "https://github.com/returnednull/tiyogo-demo-overlay/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}
